APP_NAME=PRISM API
APP_ENV=dev
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
CORS_ALLOW_CREDENTIALS=true
PURGE_CONVERSATION_ON_NEW_SESSION=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prism
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/prism

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=3072
OPENAI_TIMEOUT_SEC=90

TAVILY_API_KEY=replace-me
TAVILY_MAX_RESULTS=3
TAVILY_TIMEOUT_SEC=15

RAG_TOP_K=6
LLM_MOCK_MODE=true
STORAGE_MODE=postgres
STORAGE_DIR=runtime
